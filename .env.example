# NewsHive Environment Configuration
# Copy this file to .env and fill in your actual values

# Configuration file path (defaults to ./config.json)
NEWSHIVE_CONFIG=config.json

# State Store Path (defaults to ./state_store.json)
STATE_STORE_PATH=state_store.json

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Outlook/Azure Mail Integration (optional - email discovery is skipped if not provided)
OUTLOOK_CLIENT_ID=your-outlook-client-id
OUTLOOK_CLIENT_SECRET=your-outlook-client-secret
OUTLOOK_TENANT_ID=your-outlook-tenant-id

# Webhook URL for result delivery (Power Automate or similar)
WEBHOOK_URL=your-power-automate-webhook-url

# ==============================================================
# LLM Configuration (required for summarization & scoring)
# ==============================================================
# Choose ONE provider and set the corresponding values.
#
# Supported providers:
#   openai    — OpenAI API  (install: pip install newshive[openai])
#   anthropic — Anthropic API (install: pip install newshive[anthropic])
#   custom    — Custom/self-hosted endpoint
#
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...
#
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-sonnet-20241022
# LLM_API_KEY=sk-ant-...
#
# LLM_PROVIDER=custom
# LLM_MODEL=your-model-name
# LLM_API_KEY=your-bearer-token
# LLM_API_URL=https://your-endpoint/v1/responses
LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=
LLM_API_URL=